{
  "expo": {
    "name": "STOS Guard",
    "slug": "guard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vn.unicom.stos.guardrn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "vn.unicom.stos.guardrn",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ]
      }
    },
    "android": {
      "package": "com.stos.guard",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-location",
      [
        "expo-camera",
        {
          "cameraPermission": "Cần quyền camera để quét mã tuần tra."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://bigarvjahnxiuovepaxm.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJpZ2FydmphaG54aXVvdmVwYXhtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkxNjc0MjUsImV4cCI6MjA5NDc0MzQyNX0.t6PAcFIUs1PS77MymF4nmMbIaN-YCiADzOhk5R9_0u4",
      "pilotPrefill": true,
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "6ff19f5b-0477-4283-ab7d-106e71e6b7f9"
      }
    },
    "owner": "tuanna-unicom"
  }
}
