const { getDefaultConfig } = require("expo/metro-config");
const { withNativeWind } = require("nativewind/metro");
const path = require("path");
const fs = require("fs");

const projectRoot = __dirname;
const monorepoRoot = path.resolve(projectRoot, "../..");

process.env.EXPO_NO_METRO_WORKSPACE_ROOT = "1";
process.env.EXPO_ROUTER_APP_ROOT = process.env.EXPO_ROUTER_APP_ROOT ?? "./src/app";
process.env.EXPO_ROUTER_IMPORT_MODE =
  process.env.EXPO_ROUTER_IMPORT_MODE ?? "lazy";

const localRn = path.join(projectRoot, "node_modules", "react-native");
const rootRn = path.join(monorepoRoot, "node_modules", "react-native");
if (!fs.existsSync(localRn) && fs.existsSync(rootRn)) {
  try {
    fs.symlinkSync(rootRn, localRn, "junction");
  } catch {
    /* ignore */
  }
}

let config = getDefaultConfig(projectRoot);

config.projectRoot = projectRoot;
config.watchFolders = [
  monorepoRoot,
  path.resolve(monorepoRoot, "apps/guard/src"),
  path.resolve(monorepoRoot, "packages/shared-supabase"),
];
config.resolver.disableHierarchicalLookup = true;
config.resolver.nodeModulesPaths = [
  path.resolve(projectRoot, "node_modules"),
  path.resolve(monorepoRoot, "node_modules"),
];
config.resolver.alias = {
  "@": path.resolve(monorepoRoot, "apps/guard/src"),
  "@guard/api": path.resolve(monorepoRoot, "apps/guard/src/api"),
  "@mobile": path.resolve(projectRoot, "src"),
  "react-native": localRn,
  react: path.resolve(projectRoot, "node_modules/react"),
};

config = withNativeWind(config, { input: "./src/global.css" });

// withNativeWind có thể ghi resolver — giữ alias react-native sau cùng.
config.resolver.alias = {
  ...config.resolver.alias,
  "@": path.resolve(monorepoRoot, "apps/guard/src"),
  "@guard/api": path.resolve(monorepoRoot, "apps/guard/src/api"),
  "@mobile": path.resolve(projectRoot, "src"),
  "react-native": localRn,
  react: path.resolve(projectRoot, "node_modules/react"),
};
config.resolver.nodeModulesPaths = [
  path.resolve(projectRoot, "node_modules"),
  path.resolve(monorepoRoot, "node_modules"),
];

module.exports = config;
