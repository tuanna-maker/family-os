{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "ios-simulator": {
      "ios": {
        "simulator": true
      },
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      },
      "ios": {
        "distribution": "store"
      }
    }
  },
