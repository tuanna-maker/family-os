{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1"
      },
      "ios": {
        "distribution": "store"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
