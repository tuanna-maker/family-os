{
  "expo": {
    "name": "STOS Family",
    "slug": "stos-family-native",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "vn.unicom.stos.familyrn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.webp",
    "splash": {
      "image": "./assets/icon.webp",
      "resizeMode": "contain",
      "backgroundColor": "#071A3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "vn.unicom.stos.familyrn",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification", "fetch"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.webp",
        "backgroundColor": "#071A3D"
      },
      "package": "vn.unicom.stos.familyrn",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#071A3D",
          "image": "./assets/icon.webp",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "pilotPrefill": true,
      "eas": {
        "projectId": "29b5786e-10b8-41e9-88dd-dddbe1af9e56"
      }
    }
  }
}
