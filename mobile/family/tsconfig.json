{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "paths": {
      "@mobile/*": ["./src/*"],
      "@mobile/api/*": ["./src/api/*"],
      "@shared/supabase": ["../../packages/shared-supabase/src/index.ts"],
      "@shared/supabase/*": ["../../packages/shared-supabase/src/*"],
      "@shared/utils": ["../../packages/shared-utils/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules"]
}
