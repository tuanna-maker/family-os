{
  "name": "@mobile/family",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-status-bar"
      ],
      "android": {
        "exclude": [
          "expo-background-fetch",
          "expo-task-manager"
        ]
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "eas-build-pre-install": "cd ../.. && rm -f bun.lock bunfig.toml web/bun.lock web/bunfig.toml",
    "eas-build-post-install": "cd ../.. && node scripts/ensure-mobile-node-modules.mjs || true"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@shared/supabase": "*",
    "@shared/utils": "*",
    "@tanstack/react-query": "^5.66.11",
    "babel-plugin-module-resolver": "^5.0.2",
    "css-select": "^5.2.2",
    "expo": "~56.0.9",
    "expo-audio": "~56.0.12",
    "expo-background-fetch": "~56.0.17",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.17",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-image-picker": "~56.0.16",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-notifications": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-task-manager": "~56.0.17",
    "js-sha256": "^0.11.0",
    "lucide-react-native": "^0.475.0",
    "metro-runtime": "^0.83.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-qrcode-svg": "^6.3.14",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3"
  }
}
