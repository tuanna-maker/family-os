{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/ui": ["../../packages/shared-ui/src/index.ts"],
      "@shared/ui/*": ["../../packages/shared-ui/src/*"],
      "@shared/supabase": ["../../packages/shared-supabase/src/index.ts"],
      "@shared/supabase/*": ["../../packages/shared-supabase/src/*"],
      "@shared/utils": ["../../packages/shared-utils/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"]
}
